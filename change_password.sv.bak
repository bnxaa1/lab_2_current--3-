module change_password (
    input  logic        clk, resetN,
    input  logic        start, enter_d, done,
    input  logic        lv_correct, lv_error,
    input  logic [3:0]  switches, code,

    output logic        active, wren,
    output logic        clk_en_override, ctrRst, srst_lv,
    output logic        cp_complete, cp_fail,
    output logic [3:0]  dataIn,
    output logic [4:0]  wStartAddr, rStartAddr
);

    typedef enum logic [3:0] {
        IDLE,
        ENTRY_RST,
        ENTRY,
        VERIFY_RST,
        VERIFY_WAIT,
        VERIFY,
        COPY_PREP,
        COPY_WAIT1,
        COPY_WAIT2,
        COPY,
        DONE,
        ERROR
    } state_t;

    state_t state_reg, state_next;

    always_ff @(posedge clk, negedge resetN) begin
        if (!resetN)
            state_reg <= IDLE;
        else
            state_reg <= state_next;
    end

    always_comb begin : change_password_fsm
        state_next      = state_reg;
        active          = 1'b1;
        wren            = 1'b0;
        dataIn          = 4'b0;
        wStartAddr      = 5'd20;
        rStartAddr      = 5'd20;
        clk_en_override = 1'b0;
        ctrRst          = 1'b0;
        srst_lv         = 1'b0;
        cp_complete     = 1'b0;
        cp_fail         = 1'b0;

        case (state_reg)

            IDLE: begin
                active = 1'b0;
                if (start)
                    state_next = ENTRY_RST;
            end

            ENTRY_RST: begin
                ctrRst     = 1'b1;
                srst_lv    = 1'b1;
                wStartAddr = 5'd20;
                state_next = ENTRY;
            end

            ENTRY: begin
                srst_lv    = 1'b1;
                wStartAddr = 5'd20;
                dataIn     = switches;
                if (enter_d) begin
                    wren            = 1'b1;
                    clk_en_override = 1'b1;
                    if (switches == 4'b1010 || done)
                        state_next = VERIFY_RST;
                end
            end

            VERIFY_RST: begin
                ctrRst     = 1'b1;
                srst_lv    = 1'b1;
                rStartAddr = 5'd20;
                state_next = VERIFY_WAIT;
            end

            VERIFY_WAIT: begin
                rStartAddr = 5'd20;
                state_next = VERIFY;
            end

            VERIFY: begin
                rStartAddr = 5'd20;
                if (enter_d)
                    clk_en_override = 1'b1;
                if (lv_correct)
                    state_next = COPY_PREP;
                else if (lv_error)
                    state_next = ERROR;
            end

            COPY_PREP: begin
                ctrRst     = 1'b1;
                rStartAddr = 5'd20;
                wStartAddr = 5'd0;
                state_next = COPY_WAIT1;
            end

            COPY_WAIT1: begin
                rStartAddr = 5'd20;
                wStartAddr = 5'd0;
                state_next = COPY_WAIT2;
            end

            COPY_WAIT2: begin
                rStartAddr = 5'd20;
                wStartAddr = 5'd0;
                state_next = COPY;
            end

            COPY: begin
                rStartAddr      = 5'd20;
                wStartAddr      = 5'd0;
                wren            = 1'b1;
                dataIn          = code;
                clk_en_override = 1'b1;
                if (code == 4'b1010 || done)
                    state_next = DONE;
                else
                    state_next = COPY_WAIT1;
            end

            DONE: begin
                cp_complete = 1'b1;
                state_next  = IDLE;
            end

            ERROR: begin
                cp_fail    = 1'b1;
                state_next = IDLE;
            end

            default: state_next = IDLE;

        endcase
    end

endmodule
