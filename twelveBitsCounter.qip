set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "twelveBitsCounter_inst.v"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "twelveBitsCounter_bb.v"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "twelveBitsCounter_syn.v"]
